menu "Mozilla CA SPIFFS updater example"

    config CA_UPDATER_WIFI_SSID
        string "Wi-Fi SSID"
        default ""

    config CA_UPDATER_WIFI_PASSWORD
        string "Wi-Fi password"
        default ""

    config CA_UPDATER_MANIFEST_URL
        string "Mozilla CA bundle manifest URL"
        default ""
        help
            HTTPS URL that serves a small JSON manifest with version, URL,
            SHA-256, and size for the bundle binary.

    config CA_UPDATER_ENABLE_CONSOLE
        bool "Enable CA updater diagnostic console"
        default y
        help
            Start an ESP-IDF console after the boot-time update check. The
            console exposes commands to inspect CA state and test HTTPS URLs.

endmenu
